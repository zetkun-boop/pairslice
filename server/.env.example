# ──────────────────────────────────────────────────
#  PairSlice TMA — Environment variables
#
#  Copy this file to .env for local development:
#    cp .env.example .env
#
#  On Railway: set these in the dashboard (Variables tab).
#  Never commit the real .env file.
# ──────────────────────────────────────────────────

# Telegram bot token from @BotFather → /newbot
BOT_TOKEN=1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Full URL of the deployed Vercel frontend (no trailing slash)
FRONTEND_URL=https://pairslice.vercel.app

# Port (optional — defaults to 3000; Railway sets this automatically)
# PORT=3000

# For local development only: set this to your ngrok/tunnel hostname
# so the server can register the webhook on startup.
# Example: abc123.ngrok.io  (without https://)
# WEBHOOK_DOMAIN=abc123.ngrok.io
